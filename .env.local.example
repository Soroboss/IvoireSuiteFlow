NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-app.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key
# Optionnel (SSR / API server-side): access token InsForge si tu le stockes côté cookies et veux l'injecter
INSFORGE_EDGE_FUNCTION_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Routes API authentifiées (`/api/me`, `/api/context`) : envoyer le JWT InsForge dans
# l’en-tête Authorization: Bearer <access_token> (pas besoin de variable d’env dédiée).
